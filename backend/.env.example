# Server
SNP_PORT=:8080

# MongoDB Atlas
# Replace with your Atlas URI and DB name
SNP_MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
SNP_MONGO_DB=snp
SNP_MONGO_TIMEOUT=10s
SNP_MONGO_INSECURE_TLS=false

# Local development fallback controls
SNP_USE_LOCAL_MONGO=false
SNP_AUTO_LOCAL_MONGO_FALLBACK=true

# AI service
SNP_AI_URL=http://localhost:5000

# Linux socket + avatar storage
SNP_SOCKET_PATH=/tmp/snp.sock
SNP_AVATAR_DIR=./avatars
